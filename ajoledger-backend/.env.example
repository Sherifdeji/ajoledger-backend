# Application
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT
JWT_SECRET="a-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# Nomba API
NOMBA_BASE_URL="https://sandbox.nomba.com"
NOMBA_CLIENT_ID="your-nomba-client-id"
NOMBA_CLIENT_SECRET="your-nomba-client-secret"
# Must be the Nomba parent account ID. Team/group subaccount IDs belong only in request bodies or query params.
NOMBA_PARENT_ACCOUNT_ID="your-nomba-parent-account-id"

# Nomba Webhook
NOMBA_WEBHOOK_SECRET="your-nomba-webhook-signing-secret"
