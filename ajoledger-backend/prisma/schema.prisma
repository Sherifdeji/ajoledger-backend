// =============================================================
// AjoLedger — Prisma Domain Schema
// =============================================================
// Financial invariant: ALL monetary values are integers (kobo).
// Never store money as a float or decimal.
//
// Ledger invariant: Every Payment row MUST reference exactly one
// of (contribution_id, payout_id). The XOR constraint is enforced
// at the DB level via a custom CHECK constraint applied in
// migration: *_add_payment_xor_constraint
//
// Note: DATABASE_URL is configured in prisma.config.ts (Prisma 7)
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// ENUMS
// =============================================================

enum ContributionFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum MemberRole {
  COORDINATOR
  CONTRIBUTOR
}

enum ContributionStatus {
  PENDING
  PAID
  OVERDUE
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// =============================================================
// MODELS
// =============================================================

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  firstName          String?  @map("first_name")
  lastName           String?  @map("last_name")
  phoneNumber        String?  @map("phone_number")
  passwordHash       String   @map("password_hash")
  /// Null until the user completes the setup-transaction-pin flow (progressive profiling).
  transactionPinHash String?  @map("transaction_pin_hash")
  createdAt          DateTime @default(now()) @map("created_at")

  /// Payout bank details — set via PATCH /api/v1/users/payout-settings.
  /// Required before the PayoutsService can disburse funds to this user.
  payoutBankCode      String? @map("payout_bank_code")
  payoutAccountNumber String? @map("payout_account_number")
  payoutAccountName   String? @map("payout_account_name")

  /// Soft deletion fields (14-day retention flow)
  isDeactivated         Boolean   @default(false) @map("is_deactivated")
  scheduledDeletionDate DateTime? @map("scheduled_deletion_date")
  deletionReason        String?   @map("deletion_reason")
  deletionOtpHash       String?   @map("deletion_otp_hash")
  deletionOtpExpiresAt  DateTime? @map("deletion_otp_expires_at")

  ownedGroups SavingsGroup[]
  memberships Membership[]

  @@map("users")
}

model SavingsGroup {
  id             String   @id @default(uuid())
  name           String
  description    String?
  inviteCode     String   @unique @map("invite_code")

  frequency                     ContributionFrequency @map("frequency")
  defaultContributionAmountKobo Int                   @map("default_contribution_amount_kobo")
  maxParticipants               Int                   @map("max_participants")

  createdAt      DateTime @default(now()) @map("created_at")

  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String @map("owner_id")

  memberships Membership[]
  cycles      SavingsCycle[]

  @@map("savings_groups")
}

model Membership {
  id   String     @id @default(uuid())
  role MemberRole @default(CONTRIBUTOR)
  /// Position in the payout queue (1-indexed).
  /// Invariant: SavingsCycle.currentRound == Membership.payoutTurn
  /// identifies the active beneficiary for the current round.
  /// Nullable initially; must be fully assigned before a cycle starts.
  payoutTurn Int?     @map("payout_turn")
  joinedAt   DateTime @default(now()) @map("joined_at")

  /// Static Nomba virtual account assigned to this member for this group.
  /// Webhook transaction.aliasAccountReference MUST equal nombaAccountReference.
  virtualAccountNumber String @unique @map("virtual_account_number")
  virtualBankName      String @map("virtual_bank_name")
  virtualAccountName   String @map("virtual_account_name")
  nombaAccountReference String @unique @map("nomba_account_reference")

  group   SavingsGroup @relation(fields: [groupId], references: [id])
  groupId String       @map("group_id")

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  contributions Contribution[]
  payouts       Payout[]

  @@unique([groupId, userId])
  @@map("memberships")
}

model SavingsCycle {
  id                     String   @id @default(uuid())
  /// Amount each member pays per round, stored in kobo (integer).
  contributionAmountKobo Int      @map("contribution_amount_kobo")
  totalRounds            Int      @map("total_rounds")
  /// Starts at 1. Incremented after each successful payout.
  currentRound           Int      @default(1) @map("current_round")
  isActive               Boolean  @default(true) @map("is_active")
  startedAt              DateTime @default(now()) @map("started_at")

  group   SavingsGroup @relation(fields: [groupId], references: [id])
  groupId String       @map("group_id")

  contributions Contribution[]
  payouts       Payout[]

  @@map("savings_cycles")
}

model Contribution {
  id          String             @id @default(uuid())
  roundNumber Int                @map("round_number")
  dueDate     DateTime           @map("due_date")
  status      ContributionStatus @default(PENDING)

  cycle   SavingsCycle @relation(fields: [cycleId], references: [id])
  cycleId String       @map("cycle_id")

  membership   Membership @relation(fields: [membershipId], references: [id])
  membershipId String     @map("membership_id")

  /// One contribution is settled by at most one payment.
  payment Payment?

  @@unique([cycleId, membershipId, roundNumber])
  @@map("contributions")
}

model Payout {
  id         String       @id @default(uuid())
  /// Total disbursement in kobo: (contributionAmountKobo × totalRounds) − 2000 (₦20 network fee).
  /// The ₦20 deduction is disclosed in AjoLedger's Terms & Conditions.
  amountKobo Int          @map("amount_kobo")
  status     PayoutStatus @default(PENDING)
  /// Our generated reference sent to Nomba as merchantTxRef (format: PAYOUT-{cycleId}-R{round}).
  /// Unique — used for idempotency on both initiation and payout_success webhook lookup.
  merchantTxRef String? @unique @map("merchant_tx_ref")
  paidAt        DateTime? @map("paid_at")

  cycle   SavingsCycle @relation(fields: [cycleId], references: [id])
  cycleId String       @map("cycle_id")

  membership   Membership @relation(fields: [membershipId], references: [id])
  membershipId String     @map("membership_id")

  /// One payout is recorded by exactly one payment ledger entry.
  payment Payment?

  @@map("payouts")
}

/// Polymorphic immutable payments ledger.
///
/// INVARIANT (XOR): Exactly one of (contributionId, payoutId) MUST be non-null.
/// Enforced at the DB level by CHECK constraint in migration
/// *_add_payment_xor_constraint:
///   (contribution_id IS NULL) <> (payout_id IS NULL)
///
/// Records in this table are IMMUTABLE once written.
/// A failed payment creates a new row; it never mutates an existing one.
model Payment {
  id                  String        @id @default(uuid())
  /// Amount in kobo — must match the linked contribution or payout amount.
  amountKobo          Int           @map("amount_kobo")
  status              PaymentStatus @default(PENDING)
  /// Nomba transaction reference — unique, used for idempotency on webhook replay.
  nombaTransactionRef String?       @unique @map("nomba_transaction_ref")
  recordedAt          DateTime      @default(now()) @map("recorded_at")

  contribution   Contribution? @relation(fields: [contributionId], references: [id])
  contributionId String?       @unique @map("contribution_id")

  payout   Payout? @relation(fields: [payoutId], references: [id])
  payoutId String? @unique @map("payout_id")

  @@map("payments")
}
